# Game data extracted locally from your own SpiritVale install.
# Committed so CI can bundle it into exe releases - regenerate with extract/extract.py
# (and the IL2Cpp dump step, see README) after a game update.
extract/dumpout/
extract/dumpout_demo_backup/

# Third-party tool binaries - download separately, see README
extract/Il2CppDumper/*.exe
extract/il2cppdumper.zip

# generated build artifacts (combined_hook.js is committed - CI needs it to build the exe)
extract/frida/combined.js
extract/frida/combined_test.js
extract/frida/combined_tooltip.js
extract/frida/*.exe
build/
*.spec
SpiritValeMarket/
extract/frida/_version.py

# logs / scratch output
*.log

# python
__pycache__/
*.pyc
.venv/
